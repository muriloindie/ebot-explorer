:80 {
    root * /usr/share/caddy
    
    # Enable file server
    file_server
    
    # Try files, fallback to index.html for SPA-like behavior
    try_files {path} {path}/ /index.html
    
    # Security headers
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
    
    # Gzip compression
    encode gzip zstd
    
    # Cache static assets
    @static {
        path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot *.webp *.avif
    }
    header @static Cache-Control "public, max-age=31536000, immutable"
    
    # No cache for HTML
    @html {
        path *.html
    }
    header @html Cache-Control "no-store, no-cache, must-revalidate"
    
    # Deny access to sensitive files
    @sensitive {
        path *.env* *.git* *.htaccess *.htpasswd *.ini *.log *.sh *.sql *.conf *.bak
    }
    respond @sensitive 404
    
    # Logging
    log {
        output stdout
        format console
    }
}
