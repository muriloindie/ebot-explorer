# ================================================
# VARIÁVEIS DE AMBIENTE - Ê-BOT / Ê-SISTEMAS
# ================================================
# Copie este arquivo para .env e preencha com seus valores
# NUNCA commite o arquivo .env no git!

# ================================================
# API GROQ (OBRIGATÓRIO)
# ================================================
# Chave da API do Groq para o chat de IA
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=

# ================================================
# WHATSAPP (OPCIONAL)
# ================================================
# Número do WhatsApp para contato (formato: 5546999999999)
WHATSAPP_NUMBER=5546999130505

# ================================================
# CONFIGURAÇÕES DO SITE
# ================================================
# URL base do site (sem trailing slash)
SITE_URL=https://ebot.murilosilva.com
